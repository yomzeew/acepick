{
  "name": "acepick",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "NODE_OPTIONS=--no-experimental-strip-types expo start",
    "android": "NODE_OPTIONS=--no-experimental-strip-types expo run:android",
    "ios": "NODE_OPTIONS=--no-experimental-strip-types expo run:ios",
    "web": "NODE_OPTIONS=--no-experimental-strip-types expo start --web",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:clean": "expo run:ios --clean",
    "android:clean": "cd android && ./gradlew clean && cd .."
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^12.0.0",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "4.5.6",
    "@reduxjs/toolkit": "^2.8.2",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/react-query": "^5.75.5",
    "autoprefixer": "^10.4.20",
    "axios": "^1.9.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~53.0.27",
    "expo-av": "^15.1.7",
    "expo-constants": "~17.1.4",
    "expo-dev-client": "~5.2.4",
    "expo-device": "^7.1.4",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.5",
    "expo-local-authentication": "~16.0.5",
    "expo-localization": "~16.1.6",
    "expo-location": "^18.1.5",
    "expo-maps": "~0.11.0",
    "expo-notifications": "~0.31.5",
    "expo-print": "~14.1.4",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.3",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.9",
    "expo-status-bar": "~2.2.3",
    "lottie-react-native": "7.2.2",
    "nativewind": "^4.1.23",
    "postcss": "^8.4.49",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-svg-transformer": "^1.5.0",
    "react-native-web": "^0.20.0",
    "react-native-webrtc": "^124.0.7",
    "react-native-webview": "13.13.5",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "reselect": "^5.1.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^18.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.10",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "metro-react-native-babel-transformer": "^0.77.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.8.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-chart-kit",
          "react-native-webrtc",
          "@config-plugins/react-native-webrtc",
          "autoprefixer",
          "base64-arraybuffer",
          "postcss",
          "socket.io-client",
          "expo-av",
          "redux-persist"
        ],
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": [
        "@types/jest"
      ]
    }
  }
}
